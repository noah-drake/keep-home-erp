# Copy to .env.local for local dev, and set the same vars in your Vercel project
# (Settings -> Environment Variables, Production + Preview). NEXT_PUBLIC_* values
# are inlined into the client bundle at BUILD time, so a missing one fails the build.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only service-role key. Used ONLY by future server route handlers
# (e.g. upserting global catalog_items, which RLS forbids to normal users).
# NEVER prefix this with NEXT_PUBLIC — it must stay off the client bundle.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Product lookup (optional; sensible defaults) ---
# Which source(s) to use for barcode lookup: openfoodfacts | usda | chain (default: chain)
# PRODUCT_LOOKUP_PROVIDER=chain
# Open Food Facts requires a descriptive User-Agent or it throttles you.
# OFF_USER_AGENT=Keep-Home-ERP/0.1 (you@example.com)
# Free data.gov key for the USDA FoodData Central fallback (https://fdc.nal.usda.gov/api-key-signup).
# Without it, the USDA provider is a no-op and the chain just uses Open Food Facts.
# FDC_API_KEY=YOUR-FDC-KEY
